PORT=5000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,https://smartlingo-flax.vercel.app
CORS_CREDENTIALS=false
MONGODB_URI=
MONGODB_DB_NAME=elapp
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=SmartLingo
OTP_EXPIRES_MINUTES=10

# Payment QR settings
PAYMENT_QR_BANK_CODE=mb
PAYMENT_QR_ACCOUNT_NUMBER=
PAYMENT_QR_ACCOUNT_NAME=
PAYMENT_QR_TEMPLATE=compact2
PAYMENT_QR_TTL_SECONDS=180

# XGate sync settings
XGATE_API_KEY=
XGATE_API_URL=https://xgate.vn/api/v1/transactions
XGATE_TRANSACTIONS_ENDPOINT=/transactions
XGATE_ACCOUNT=
XGATE_TYPE=in
XGATE_PAGE_LIMIT=50
XGATE_MAX_REQUESTS_PER_RUN=1
# Per-minute cap for user reconcile (1 XGate call per poll, separate from bulk sync limit)
XGATE_FOCUS_RATE_LIMIT_PER_MINUTE=30
# Optional: filter transactions by bank code (vpb, vcb, tcb...)
XGATE_BANK=
XGATE_SYNC_ENABLED=false
XGATE_SYNC_INTERVAL_MS=300000

# Revenue reporting
REVENUE_TIMEZONE=Asia/Ho_Chi_Minh

# AI exercise builder (uses OPENAI_API_KEY from your environment)
# EXERCISE_AI_OPENAI_MODEL=gpt-4o-mini
# EXERCISE_AI_MAX_PDF_CHARS=12000
# EXERCISE_AI_TIMEOUT_MS=120000
# MAX_PDF_SIZE_MB=10
